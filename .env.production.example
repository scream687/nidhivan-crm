# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=nidhivan
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=nidhivan_crm
DATABASE_URL=postgresql://nidhivan:CHANGE_ME_strong_password@db:5432/nidhivan_crm

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379

# ─── Auth (min 32 chars each) ─────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_at_least_32_char_jwt_secret_here
JWT_REFRESH_SECRET=CHANGE_ME_at_least_32_char_refresh_secret

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://your-domain.com

# ─── Next.js ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1
NEXT_TELEMETRY_DISABLED=1

# ─── Sentry (optional — error tracking activates only when DSN is set) ────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── Integrations (optional) ──────────────────────────────────────────────────
EXOTEL_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_CALLER_ID=
FB_VERIFY_TOKEN=
FB_PAGE_ACCESS_TOKEN=
